{% extends 'base.html.twig' %}

{% block title %}Dashboard {{ dashboardId }}{% endblock %}

{% block body %}
    <h1>Dashboard {{ dashboardId }}</h1>

    <p>Showing All 10,000 records with pagination</p>
    <p>Please <a href="{{ path('dashboard_index', {id: 123}) }}">Click here </a>to show the records without pagination</p>

    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>#</th>
                <th>Record</th>
            </tr>
        </thead>
        <tbody>
            {% for record in records %}
                <tr>
                    <td>{{ loop.index + ((page - 1) * 50) }}</td>
                    <td>{{ record }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="pagination">
        {% if page > 1 %}
            <a href="{{ path('dashboard_records', {id: dashboardId, page: page - 1}) }}">Previous</a>
        {% endif %}

        <span>Page {{ page }} of {{ totalPages }}</span>

        {% if page < totalPages %}
            <a href="{{ path('dashboard_records', {id: dashboardId, page: page + 1}) }}">Next</a>
        {% endif %}
    </div>
    

    <p>Showing All 10,000 records with pagination</p>
    <p>Please <a href="{{ path('dashboard_index', {id: 123}) }}">Click here </a>to show the records without pagination</p>
{% endblock %}
